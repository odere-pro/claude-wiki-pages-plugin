# OS
.DS_Store
Thumbs.db

# Claude Code plugin development artifacts
.claude/settings.local.json
.claude/worktrees/
.claude/memory/
.claude/claude-wiki-pages/
.claude/calibration/
# Per-machine plugin config (localModel endpoint/model choice) — never imposed
# on contributors; see templates/default.config.json for the shape.
.claude/claude-wiki-pages.json
CLAUDE.local.md

# Local scratch space (plans, drafts)
tmp/

# Obsidian config and app state — never tracked. The whole .obsidian/ directory
# is regenerable cache (ADR-0023): the obsidian-graph-colors skill writes the
# minimum graph.json scaffold (initial filters) and the app.json wiki-only
# exclusions when absent, and the polish agent asserts them after every ingest.
# Nothing under .obsidian/ is shipped tracked — it is generated per vault.
**/.obsidian/
**/.trash/
**/.dataview/
**/.smart-connections/
**/.copilot/

# Node / Bun
node_modules/

# Bun engine build output (rebuilt by `doctor` D06 / prepublish)
dist/
*.tsbuildinfo

# Bats test helpers (cloned at test time; do not commit)
tests/test_helper/bats-assert/
tests/test_helper/bats-support/
tests/test_helper/bats-file/

# Vault output scratch space (user projects and the reference demo)
vault/output/

# Plugin wiki vault — tracked in the repo as the project knowledge base.
# Only the scratch output/ subdirectory and the _inbox/ stub quarantine are ignored.
docs/claude-wiki-pages-plugin-vault/output/
docs/claude-wiki-pages-plugin-vault/_inbox/

# Large binary assets in raw/
**/raw/assets/*.pdf
**/raw/assets/*.mp3
**/raw/assets/*.mp4
**/raw/assets/*.wav
**/raw/assets/*.webm
**/raw/assets/*.zip
**/raw/assets/*.epub

# Stray in-vault wiki settings: resolve-vault.sh auto-creates a settings.json
# (defaulting to docs/vault) whenever a wiki script runs with cwd inside the
# vault. The resolver only reads the repo-root file, so these are junk — never
# read, never correct. Keep them out of Source Control.
docs/claude-wiki-pages-plugin-vault/**/.claude/
