# OS
.DS_Store
Thumbs.db

# Claude Code plugin development artifacts
.claude/settings.local.json
.claude/worktrees/
.claude/memory/
.claude/claude-wiki-pages/
.claude/calibration/
# Per-machine plugin config (localModel endpoint/model choice) — never imposed
# on contributors; see templates/default.config.json for the shape.
.claude/claude-wiki-pages.json
CLAUDE.local.md

# Local scratch space (plans, drafts)
tmp/

# Obsidian app state (applies to user vaults and vault-example/)
**/.obsidian/
# …except the plugin-shipped initial graph configuration (initial filters +
# wiki-only exclusions + scaffold source for new vaults). Re-include the dir,
# re-ignore its contents, then re-include ONLY graph.json + app.json — other
# app-state files stay untracked.
!skills/init/template/.obsidian/
skills/init/template/.obsidian/*
!skills/init/template/.obsidian/graph.json
!skills/init/template/.obsidian/app.json
!docs/vault-example/.obsidian/
docs/vault-example/.obsidian/*
!docs/vault-example/.obsidian/graph.json
!docs/vault-example/.obsidian/app.json
**/.trash/
**/.dataview/
**/.smart-connections/
**/.copilot/

# Node / Bun
node_modules/

# Bun engine build output (rebuilt by `doctor` D06 / prepublish)
dist/
*.tsbuildinfo

# Bats test helpers (cloned at test time; do not commit)
tests/test_helper/bats-assert/
tests/test_helper/bats-support/
tests/test_helper/bats-file/

# Vault output scratch space (user projects and the reference demo)
vault/output/
**/vault-example/output/

# Generated dogfood vault — local working artifact, regenerated per run, never tracked.
# Parity anchor is docs/vault-example/ (kept). Resolver pointer is local-only.
docs/claude-wiki-pages-plugin-vault/

# Large binary assets in raw/
**/raw/assets/*.pdf
**/raw/assets/*.mp3
**/raw/assets/*.mp4
**/raw/assets/*.wav
**/raw/assets/*.webm
**/raw/assets/*.zip
**/raw/assets/*.epub
