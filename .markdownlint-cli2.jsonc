{
  "config": {
    "default": true,
    "MD013": false,
    "MD033": false,
    "MD040": false,
    "MD041": false,
    "MD060": false,
    "MD024": {
      "siblings_only": true,
    },
    "MD025": {
      "front_matter_title": "",
    },
    "MD046": {
      "style": "fenced",
    },
  },
  "ignores": [
    "node_modules",
    "tmp",
    ".claude/worktrees",
    "tests/test_helper",
    "docs/vault-example/raw",
    "docs/vault-example/wiki/log.md",
    ".claude/fixtures",
    // As-emitted ADR-0011 evidence: reformatting would change the scores and
    // break --verify-artifact reproduction.
    "tests/eval/runs",
    // Vault content is data, not project prose: the dogfood vault, Obsidian
    // config trees, and raw documents are never grouped or indexed by the
    // normalization gates (same class as .claude/fixtures).
    "docs/vault",
    "**/.obsidian",
  ],
}
